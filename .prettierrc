{
    "semi": true,
    "singleQuote": false,
    "tabWidth": 4,
    "useTabs": false,
    "trailingComma": "all",
    "printWidth": 120,
    "bracketSpacing": true,
    "endOfLine": "lf",
    "arrowParens": "always",
    "proseWrap": "preserve",
    "overrides": [
        {
            "files": ["**/*.yml", "**/*.yaml"],
            "options": {
                "tabWidth": 2,
                "singleQuote": false
            }
        },
        {
            "files": ["**/*.md"],
            "options": {
                "proseWrap": "always"
            }
        },
        {
            "files": ["**/*.json"],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
