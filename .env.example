# ============================================================
# Environment Configuration Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_NAME="FastAPI Microservice"
APP_VERSION="1.0.0"
APP_DESCRIPTION="Production-ready FastAPI microservice"
ENVIRONMENT="development"           # development | staging | production
DEBUG=true

# --- Server ---
HOST="0.0.0.0"
PORT=8000
WORKERS=1                           # Increase in production (match CPU cores)
RELOAD=true                         # Hot-reload (dev only — set false in prod)

# --- API ---
API_V1_STR="/api/v1"

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY="CHANGE_ME_TO_A_SECURE_RANDOM_64_BYTE_HEX_STRING" # pragma: allowlist secret
ALGORITHM="RS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Oathkeeper-compatible JWT claims ---
# JWKS_URL: URL to fetch Oathkeeper's public JSON Web Key Set (JWKS)
#   Used to cryptographically verify ID tokens produced by Oathkeeper's id_token mutator.
JWKS_URL="http://oathkeeper:4456/.well-known/jwks.json"
# JWT_ISSUER: value of the 'iss' claim.
#   Must match `trusted_issuers` in your Oathkeeper jwt authenticator config.
JWT_ISSUER="http://localhost:8000"
# JWT_AUDIENCE: value(s) of the 'aud' claim.
#   Must match `target_audience` in your Oathkeeper jwt authenticator config.
#   Comma-separated string or JSON array both accepted.
JWT_AUDIENCE="http://localhost:8000"

# --- Database (PostgreSQL) ---
POSTGRES_SERVER="localhost"
POSTGRES_PORT=5432
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres" # pragma: allowlist secret
POSTGRES_DB="fastapi_db"
# Overrides individual POSTGRES_* vars if set:
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/fastapi_db" # pragma: allowlist secret

# Database Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false                       # Log all SQL statements (dev only)

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"
CORS_ALLOW_CREDENTIALS=true

# --- Logging ---
LOG_LEVEL="INFO"                    # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT="json"                   # json | text
LOG_FILE=""                         # Optional: path to log file

# --- Redis (docker compose --profile cache) ---
# REDIS_HOST="redis"
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD="changeme" # pragma: allowlist secret

# --- PgAdmin (docker compose --profile tools) ---
# PGADMIN_EMAIL="admin@example.com"
# PGADMIN_PASSWORD="admin" # pragma: allowlist secret

# --- Grafana (docker compose --profile monitoring) ---
# GRAFANA_USER="admin"
# GRAFANA_PASSWORD="admin" # pragma: allowlist secret

# --- Message Broker (Future) ---
# KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
# RABBITMQ_URL="amqp://guest:guest@localhost:5672/" # pragma: allowlist secret

# --- Observability (Future) ---
# SENTRY_DSN=""
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
# PROMETHEUS_METRICS_ENABLED=false
